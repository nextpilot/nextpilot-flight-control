mainmenu "RT-Thread Configuration"

# 1. 变量立即赋值，简单展开，立即求值
# RTT_DIR  := ../../../rtos/rt-thread
# PKGS_DIR := ../../../rtos/packages
#
# 2. 变量延迟赋值，使用的时候才展开
# CC = $(CROSS_TOOL)gcc
#
# 3. 追加赋值
# VAR += ADDITIONAL
#
# 4. 变量引用，含环境变量，采用$(VAR)
# rsource "$(RTT_DIR)/Kconfig"
# osource "$(PKGS_DIR)/Kconfig"
#
# 5. 引用环境变量
#  $(VAR)   可以引用变量和环境变量，优先使用Kconfig中变量，没有则在环境变量中搜索，可以用于所有语句
#  $ENV_VAR 只能引用环境变量，直接在环境变量中搜索，且只能用于source命令
#
# 6. 内置函数
# $(shell, command)  执行shell命令
# $(info, text)      打印信息
# $(warning-if, condition, text)
# $(error-if, condition, text)
# $(filename)         当前文件名
# $(lineno)           当前行号


RTT_DIR := ../../../rtos/rt-thread
PKGS_DIR := ../../../rtos/packages

rsource "$(RTT_DIR)/Kconfig"
#osource "$(PKGS_DIR)/Kconfig"
rsource "board/Kconfig"
